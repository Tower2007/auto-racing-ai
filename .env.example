# Gmail SMTP (週次ステータスレポート用、boat-racing-ai と同じ命名)
GMAIL_USER=no28akira2007@gmail.com
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx
MAIL_TO=no28akira2007@gmail.com

# 夜間限定 自動投票 Phase 1 (auto_buy.py、デフォルト全て安全側)
# AUTO_BUY_ENABLED=false        # マスタースイッチ (未設定=false=従来 click-to-buy のみ)
# AUTO_BUY_DRY_RUN=true         # true=実投票せず log のみ (Week1)
# AUTO_BUY_INCLUDE_RT3=false    # true=三連系も自動 (Week3)、false=複勝のみ
# AUTO_BUY_ANYTIME=true         # true=時間帯無視で常時発注 (デフォルト)、false=夜間限定
# AUTO_BUY_HOUR_START=22        # 夜間限定時の 開始時刻 (JST、ANYTIME=false 時のみ)
# AUTO_BUY_HOUR_END=6           # 夜間限定時の 終了時刻 (JST、22>6 は日跨ぎ)
# MAX_DAILY_AUTO_YEN=3000       # 1 日合計上限
# DAILY_LOSS_STOP_YEN=-3000     # 当日損益がこれ以下で以降 skip
# EV_ANOMALY_CAP=10.0           # EV がこれ超のレースは skip (バグ防御)
# CONSECUTIVE_FAILURES_STOP=3   # 連続失敗でこの回数到達で停止
# AUTO_BUY_NOTIFY_TO=           # 自動投票通知の宛先 (未設定なら MAIL_TO)
